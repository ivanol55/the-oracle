---
import Layout from '../layouts/Layout.astro';

---

<Layout title="The Oracle">
	<main>
		<div class="hero">
			<h1>the <span class="text-gradient">Oracle</span></h1>
			<p class="subtitle">
				If a customer has asked it in an RFI before, I probably know it. Ask a question, get the closest answer.
				Take what I say with a grain of salt, I'm just a math function!
			</p>
		</div>

		<section class="card search-card">
			<form id="search-form">
				<div class="input-group">
					<svg class="search-icon" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
						<path stroke-linecap="round" stroke-linejoin="round" d="m21 21-5.197-5.197m0 0A7.5 7.5 0 1 0 5.196 5.196a7.5 7.5 0 0 0 10.607 10.607Z" />
					</svg>
					<input type="search" id="question" placeholder="What do you want to know?" autocomplete="off" />
				</div>
				<button type="submit" class="btn btn-primary">Ask the Oracle</button>
			</form>
		</section>

		<section class="card response-card hidden" id="response-card">
			<div id="response-container"></div>
		</section>

		<section class="card bulk-card">
			<div class="bulk-header">
				<svg class="bulk-icon" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
					<path stroke-linecap="round" stroke-linejoin="round" d="M19.5 14.25v-2.625a3.375 3.375 0 0 0-3.375-3.375h-1.5A1.125 1.125 0 0 1 13.5 7.125v-1.5a3.375 3.375 0 0 0-3.375-3.375H8.25m6.75 12H9.75m0 0-2.625 2.625M9.75 15.75l-2.625-2.625M6.75 7.5H4.875c-.621 0-1.125.504-1.125 1.125v12c0 .621.504 1.125 1.125 1.125h9.75c.621 0 1.125-.504 1.125-1.125V16.5a9 9 0 0 0-9-9Z" />
				</svg>
				<div>
					<h3>Bulk answers</h3>
					<p>Got a full questionnaire? <a href="http://localhost:8080/template" class="link">Download the CSV template</a>, fill in your questions, and upload it.</p>
				</div>
			</div>
			<form id="bulk-form" class="bulk-form">
				<label class="file-input-label">
					<span id="file-label-text">Choose CSV file...</span>
					<input type="file" id="bulk-file" accept=".csv" class="file-input-hidden" />
				</label>
				<button type="submit" class="btn btn-secondary">Upload and get answers</button>
			</form>
			<p id="bulk-status" class="bulk-status"></p>
		</section>
	</main>

	<script>
		const responseCard = document.getElementById('response-card')!;
		const responseContainer = document.getElementById('response-container')!;

		document.getElementById('search-form')?.addEventListener('submit', function(event) {
		  event.preventDefault();
		  const question = (document.getElementById('question') as HTMLInputElement).value;
		  if (!question.trim()) return;

		  responseCard.classList.remove('hidden');
		  responseContainer.innerHTML = '<div class="loading"><span></span><span></span><span></span></div>';

		  fetch('http://localhost:8080/ask', {
			method: 'POST',
			headers: { 'Content-Type': 'application/json' },
			body: JSON.stringify({ question })
		  })
		  .then(response => response.json())
		  .then(data => {
			if (!data.response) {
			  responseContainer.innerHTML = '<div class="no-answer">No confident answer found for that question. Try rephrasing, or reach out to the team directly.</div>';
			} else {
			  const conf = data.response.confidence;
			  const level = conf >= 70 ? 'high' : conf >= 50 ? 'mid' : 'low';
			  responseContainer.innerHTML =
				'<p class="answer-text">' + data.response.metadata.answer + '</p>'
				+ '<div class="answer-footer">'
				+ '<div class="confidence-row">'
				+ '<span class="meta-label">Confidence</span>'
				+ '<div class="confidence-bar"><div class="confidence-fill ' + level + '" style="width:' + conf + '%"></div></div>'
				+ '<span class="confidence-value ' + level + '">' + conf + '%</span>'
				+ '</div>'
				+ '<div class="owner-row">'
				+ '<span class="meta-label">Owner</span>'
				+ '<span class="owner-badge">' + data.response.metadata.owner + '</span>'
				+ '</div>'
				+ '</div>';
			}
		  })
		  .catch(() => {
			responseContainer.innerHTML = '<div class="no-answer">Something went wrong. Please try again.</div>';
		  });
		});

		document.getElementById('bulk-file')?.addEventListener('change', function() {
		  const fileInput = this as HTMLInputElement;
		  const label = document.getElementById('file-label-text')!;
		  label.textContent = fileInput.files?.[0]?.name || 'Choose CSV file...';
		});

		document.getElementById('bulk-form')?.addEventListener('submit', function(event) {
		  event.preventDefault();
		  const fileInput = document.getElementById('bulk-file') as HTMLInputElement;
		  const status = document.getElementById('bulk-status')!;

		  if (!fileInput.files || !fileInput.files[0]) {
			status.textContent = 'Please select a CSV file first.';
			status.className = 'bulk-status error';
			return;
		  }

		  status.textContent = 'Processing...';
		  status.className = 'bulk-status';
		  const formData = new FormData();
		  formData.append('file', fileInput.files[0]);

		  fetch('http://localhost:8080/bulk', {
			method: 'POST',
			body: formData,
		  })
		  .then(response => {
			if (!response.ok) throw new Error('Upload failed');
			return response.blob();
		  })
		  .then(blob => {
			const url = URL.createObjectURL(blob);
			const a = document.createElement('a');
			a.href = url;
			a.download = 'oracle_answers.csv';
			a.click();
			URL.revokeObjectURL(url);
			status.textContent = 'Done! Your answers file has been downloaded.';
			status.className = 'bulk-status success';
		  })
		  .catch(() => {
			status.textContent = 'Something went wrong. Please try again.';
			status.className = 'bulk-status error';
		  });
		});
	</script>

</Layout>

<style is:global>
	/* Dynamic response content (injected via innerHTML at runtime) */
	.answer-text {
		margin: 0;
		font-size: 1rem;
		line-height: 1.75;
	}
	.answer-footer {
		border-top: 1px solid var(--surface-border);
		margin-top: 1.25rem;
		padding-top: 1rem;
		display: flex;
		flex-direction: column;
		gap: 0.75rem;
	}
	.confidence-row, .owner-row {
		display: flex;
		align-items: center;
		gap: 0.75rem;
	}
	.meta-label {
		font-size: 0.8rem;
		font-weight: 500;
		color: var(--text-secondary);
		min-width: 80px;
		flex-shrink: 0;
	}
	.confidence-bar {
		flex: 1;
		height: 6px;
		background: rgba(255, 255, 255, 0.06);
		border-radius: 3px;
		overflow: hidden;
	}
	.confidence-fill {
		height: 100%;
		border-radius: 3px;
		transition: width 0.5s ease;
	}
	.confidence-fill.high { background: rgb(var(--success)); }
	.confidence-fill.mid  { background: rgb(var(--warning)); }
	.confidence-fill.low  { background: rgb(var(--danger)); }
	.confidence-value {
		font-size: 0.85rem;
		font-weight: 700;
		min-width: 36px;
		text-align: right;
	}
	.confidence-value.high { color: rgb(var(--success)); }
	.confidence-value.mid  { color: rgb(var(--warning)); }
	.confidence-value.low  { color: rgb(var(--danger)); }
	.owner-badge {
		display: inline-flex;
		align-items: center;
		padding: 4px 12px;
		border-radius: 6px;
		font-size: 0.8rem;
		font-weight: 600;
		background: rgba(var(--accent-light), 0.12);
		color: rgb(var(--accent-light));
	}
	.no-answer {
		color: var(--text-secondary);
		font-style: italic;
	}
	.loading {
		display: flex;
		gap: 6px;
		justify-content: center;
		padding: 1rem 0;
	}
	.loading span {
		width: 8px;
		height: 8px;
		border-radius: 50%;
		background: rgb(var(--accent-light));
		animation: pulse 1.2s ease-in-out infinite;
	}
	.loading span:nth-child(2) { animation-delay: 0.15s; }
	.loading span:nth-child(3) { animation-delay: 0.3s; }
	@keyframes pulse {
		0%, 80%, 100% { opacity: 0.25; transform: scale(0.8); }
		40% { opacity: 1; transform: scale(1); }
	}
</style>

<style>
	main {
		position: relative;
		z-index: 1;
		margin: auto;
		padding: 2rem 1.5rem 4rem;
		width: 100%;
		max-width: 960px;
		font-size: 16px;
		line-height: 1.7;
	}

	/* Hero */
	.hero {
		text-align: center;
		padding: 3rem 0 2rem;
	}
	.hero h1 {
		font-size: 3rem;
		font-weight: 700;
		letter-spacing: -0.03em;
		margin: 0 0 0.75rem;
	}
	.text-gradient {
		background-image: var(--accent-gradient);
		-webkit-background-clip: text;
		-webkit-text-fill-color: transparent;
		background-clip: text;
	}
	.subtitle {
		color: var(--text-secondary);
		font-size: 1.05rem;
		max-width: 800px;
		margin: 0 auto;
		line-height: 1.6;
	}

	/* Cards */
	.card {
		background: var(--surface);
		border: 1px solid var(--surface-border);
		border-radius: 12px;
		padding: 1.5rem;
		margin-bottom: 1rem;
		backdrop-filter: blur(12px);
		transition: opacity 0.3s ease, transform 0.3s ease;
	}
	.card.hidden {
		display: none;
	}

	/* Search */
	.input-group {
		position: relative;
		margin-bottom: 1rem;
	}
	.search-icon {
		position: absolute;
		left: 14px;
		top: 50%;
		transform: translateY(-50%);
		width: 20px;
		height: 20px;
		color: var(--text-secondary);
		pointer-events: none;
	}
	#question {
		width: 100%;
		padding: 14px 16px 14px 44px;
		background: rgba(255, 255, 255, 0.06);
		border: 1px solid var(--surface-border);
		border-radius: 10px;
		color: var(--text-primary);
		font-size: 1rem;
		font-family: inherit;
		outline: none;
		transition: border-color 0.2s, box-shadow 0.2s;
	}
	#question::placeholder {
		color: var(--text-secondary);
	}
	#question:focus {
		border-color: rgba(var(--accent-light), 0.5);
		box-shadow: 0 0 0 3px rgba(var(--accent), 0.15);
	}

	/* Buttons */
	.btn {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		padding: 10px 24px;
		border: none;
		border-radius: 8px;
		font-size: 0.9rem;
		font-weight: 600;
		font-family: inherit;
		cursor: pointer;
		transition: all 0.2s;
	}
	.btn-primary {
		width: 100%;
		background: linear-gradient(135deg, rgb(var(--accent)), rgb(var(--accent-light)));
		color: white;
		box-shadow: 0 2px 12px rgba(var(--accent), 0.3);
	}
	.btn-primary:hover {
		box-shadow: 0 4px 20px rgba(var(--accent), 0.45);
		transform: translateY(-1px);
	}
	.btn-secondary {
		background: rgba(255, 255, 255, 0.08);
		color: var(--text-primary);
		border: 1px solid var(--surface-border);
		white-space: nowrap;
	}
	.btn-secondary:hover {
		background: var(--surface-hover);
	}

	/* Response (static) */
	.response-card {
		border-color: rgba(var(--accent-light), 0.15);
	}

	/* Bulk */
	.bulk-card {
		margin-top: 2rem;
		border-color: rgba(var(--accent-light), 0.1);
	}
	.bulk-header {
		display: flex;
		gap: 1rem;
		align-items: flex-start;
		margin-bottom: 1rem;
	}
	.bulk-icon {
		width: 28px;
		height: 28px;
		flex-shrink: 0;
		color: rgb(var(--accent-light));
		margin-top: 2px;
	}
	.bulk-header h3 {
		margin: 0 0 0.25rem;
		font-size: 1.05rem;
		font-weight: 600;
	}
	.bulk-header p {
		margin: 0;
		color: var(--text-secondary);
		font-size: 0.9rem;
	}
	.link {
		color: rgb(var(--accent-light));
		text-decoration: none;
		border-bottom: 1px solid rgba(var(--accent-light), 0.3);
		transition: border-color 0.2s;
	}
	.link:hover {
		border-color: rgb(var(--accent-light));
	}
	.bulk-form {
		display: flex;
		gap: 0.75rem;
		align-items: center;
	}
	.file-input-label {
		flex: 1;
		display: flex;
		align-items: center;
		padding: 10px 16px;
		background: rgba(255, 255, 255, 0.06);
		border: 1px dashed var(--surface-border);
		border-radius: 8px;
		color: var(--text-secondary);
		font-size: 0.9rem;
		cursor: pointer;
		transition: border-color 0.2s;
		overflow: hidden;
	}
	.file-input-label:hover {
		border-color: rgba(var(--accent-light), 0.4);
	}
	.file-input-hidden {
		display: none;
	}
	.bulk-status {
		font-size: 0.85rem;
		margin-top: 0.5rem;
		color: var(--text-secondary);
	}
	.bulk-status.success {
		color: rgb(var(--success));
	}
	.bulk-status.error {
		color: rgb(var(--danger));
	}

	/* Mobile */
	@media (max-width: 600px) {
		main { padding: 1rem; }
		.hero h1 { font-size: 2.25rem; }
		.bulk-form { flex-direction: column; }
		.btn-secondary { width: 100%; }
	}
</style>
