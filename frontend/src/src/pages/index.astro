---
import Layout from '../layouts/Layout.astro';

---

<Layout title="Welcome to the Oracle">
	<main>
		<h1 class="pt-10 text-4xl box-content">Welcome to <span class="text-gradient">the Oracle</span></h1>
		<p class="instructions text-center w-full">
			Find the answers you need for your <code>compliance</code> questions, based on the wizardry of 
			<strong>proximity search</strong> across the Oracle's knowledgebase. I'm just a machine, though, so take what I say with a grain of salt!
		</p>
		<form id="search-form">
			<label for="default-search" class="mb-2 text-sm font-medium text-gray-900 sr-only">Search</label>
			<div class="relative">
				<div class="absolute inset-y-0 left-0 flex items-center pl-3 pointer-events-none">
					<svg class="w-4 h-4 text-gray-500 dark:text-gray-400" aria-hidden="true" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 20 20">
						<path stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="m19 19-4-4m0-7A7 7 0 1 1 1 8a7 7 0 0 1 14 0Z"/>
					</svg>
				</div>
				<input type="search" id="question" class=" m-auto mb-4 block w-full p-4 pl-10 text-sm text-gray-900 border border-gray-300 rounded-lg bg-gray-50 focus:ring-blue-500 focus:border-blue-500" placeholder="What do you want to know?">
			</div>
			<div class="flex items-center pl-3">
				<input type="submit" class="mx-auto text-white bg-blue-700 hover:bg-blue-800 focus:ring-4 focus:outline-none focus:ring-blue-300 font-medium rounded-lg text-sm w-1/4 px-5 py-2.5 text-center dark:bg-blue-600 dark:hover:bg-blue-700 dark:focus:ring-blue-800" value="Request the wisdom of the Oracle"/>
		</div>
		</form>
		<br/>
		<p class="response text-justify w-full" id="response-container">
			The <code>oracle's wisdom</code> will be displayed once the search is done
		</p>

		<div class="bulk-banner">
			<p><strong>Got a lot of questions?</strong>
				<a href="http://localhost:8080/template" class="bulk-link">Download the CSV template</a>,
				fill in your questions, and upload it to get answers in bulk.
			</p>
			<form id="bulk-form" class="mt-4 flex items-center gap-4">
				<input type="file" id="bulk-file" accept=".csv" class="text-sm file:mr-4 file:py-2 file:px-4 file:rounded-lg file:border-0 file:text-sm file:font-medium file:bg-blue-600 file:text-white hover:file:bg-blue-700 file:cursor-pointer"/>
				<input type="submit" class="text-white bg-blue-700 hover:bg-blue-800 focus:ring-4 focus:outline-none focus:ring-blue-300 font-medium rounded-lg text-sm px-5 py-2.5 dark:bg-blue-600 dark:hover:bg-blue-700 dark:focus:ring-blue-800 cursor-pointer" value="Upload and get answers"/>
			</form>
			<p id="bulk-status" class="mt-2 text-sm"></p>
		</div>
	</main>

	<script>
		// Function to handle form submission
		document.getElementById('search-form')?.addEventListener('submit', function(event) {
		  event.preventDefault(); // Prevent default form submission
	  
		  // Get the question from the form input
		  
		  const question = (document.getElementById('question') as HTMLInputElement).value;
		  // Make a POST request to the API endpoint
		  fetch('http://localhost:8080/ask', {
			method: 'POST',
			headers: {
			  'Content-Type': 'application/json'
			},
			body: JSON.stringify({ question })
		  })
		  .then(response => response.json())
		  .then(data => {
		const container = document.getElementById('response-container')!;
		if (!data.response) {
		  container.innerHTML = "The Oracle doesn't have a confident answer for that question. Try rephrasing, or reach out to the team directly.";
		} else {
		  container.innerHTML = data.response.metadata.answer
			+ "<br/><br/><code>Confidence: " + data.response.confidence + "%</code>"
			+ " &middot; Assigned to: <code>" + data.response.metadata.owner + "</code>";
		}
	  })
		  .catch(error => {
			console.error('Error:', error);
		  });
		});

		document.getElementById('bulk-form')?.addEventListener('submit', function(event) {
		  event.preventDefault();
		  const fileInput = document.getElementById('bulk-file') as HTMLInputElement;
		  const status = document.getElementById('bulk-status')!;

		  if (!fileInput.files || !fileInput.files[0]) {
			status.textContent = 'Please select a CSV file first.';
			return;
		  }

		  status.textContent = 'Processing...';
		  const formData = new FormData();
		  formData.append('file', fileInput.files[0]);

		  fetch('http://localhost:8080/bulk', {
			method: 'POST',
			body: formData,
		  })
		  .then(response => {
			if (!response.ok) throw new Error('Upload failed');
			return response.blob();
		  })
		  .then(blob => {
			const url = URL.createObjectURL(blob);
			const a = document.createElement('a');
			a.href = url;
			a.download = 'oracle_answers.csv';
			a.click();
			URL.revokeObjectURL(url);
			status.textContent = 'Done! Your answers file has been downloaded.';
		  })
		  .catch(error => {
			console.error('Error:', error);
			status.textContent = 'Something went wrong. Please try again.';
		  });
		});
	  </script>
	  
</Layout>

<style>
	main {
		margin: auto;
		padding: 1rem;
		width: calc(75% - 2rem);
		max-width: calc(100% - 2rem);
		color: white;
		font-size: 20px;
		line-height: 1.6;
	}

	@media (pointer:none), (pointer:coarse) {
		main {
		width: auto;
		}
	}	

	h1 {
		font-weight: 700;
		line-height: 1;
		text-align: center;
		margin-bottom: 1em;
	}
	.text-gradient {
		background-image: var(--accent-gradient);
		-webkit-background-clip: text;
		-webkit-text-fill-color: transparent;
		background-size: 400%;
		background-position: 0%;
	}
	.instructions {
		margin-bottom: 2rem;
		border: 1px solid rgba(var(--accent-light), 25%);
		background: linear-gradient(rgba(var(--accent-dark), 66%), rgba(var(--accent-dark), 33%));
		padding: 1.5rem;
		border-radius: 8px;
	}
	.instructions code {
		font-size: 0.8em;
		font-weight: bold;
		background: rgba(var(--accent-light), 12%);
		color: rgb(var(--accent-light));
		border-radius: 4px;
		padding: 0.3em 0.4em;
	}
	.instructions strong {
		color: rgb(var(--accent-light));
	}
	.response {
		margin-bottom: 2rem;
		border: 1px solid rgba(var(--accent-light), 25%);
		background: #eb4961;
		padding: 1.5rem;
		border-radius: 8px;
	}
	.bulk-banner {
		margin-bottom: 2rem;
		border: 1px solid rgba(var(--accent-light), 25%);
		background: linear-gradient(rgba(var(--accent-dark), 66%), rgba(var(--accent-dark), 33%));
		padding: 1.5rem;
		border-radius: 8px;
	}
	.bulk-link {
		color: rgb(var(--accent-light));
		text-decoration: underline;
	}
	.response code {
		font-size: 0.8em;
		font-weight: bold;
		background: rgba(var(--accent-light), 12%);
		color: white;
		border-radius: 4px;
		padding: 0.3em 0.4em;
	}
</style>
